[{"ownerId": "barber", "targetId": "cult_leader", "ownerEn": "Barber", "targetEn": "Cult Leader", "newCn": "通过理发师交换的邪恶异教领袖无法因为自身能力转变为善良阵营。"}, {"ownerId": "barber", "targetId": "damsel", "ownerEn": "Barber", "targetEn": "Damsel", "newCn": "如果恶魔选择交换落难少女的角色，参与角色交换的另一名玩家改为由说书人来决定。"}, {"ownerId": "barber", "targetId": "goon", "ownerEn": "Barber", "targetEn": "Goon", "newCn": "通过理发师交换的邪恶莽夫无法因为自身能力转变为善良阵营。"}, {"ownerId": "barber", "targetId": "politician", "ownerEn": "Barber", "targetEn": "Politician", "newCn": "通过理发师交换的邪恶政客无法因为自身能力转变为善良阵营。"}, {"ownerId": "boffin", "targetId": "wudaozhe", "ownerEn": "Boffin", "targetEn": "Enlightened One", "newCn": "恶魔无法拥有悟道者的能力。"}, {"ownerId": "guhuoniao", "targetId": "exorcist", "ownerEn": "Guhuo", "targetEn": "Exorcist", "newCn": "一名已获得过爪牙能力的姑获鸟被驱魔人选中，他能够因为爪牙的能力被唤醒。"}, {"ownerId": "guhuoniao", "targetId": "mastermind", "ownerEn": "Guhuo", "targetEn": "Mastermind", "newCn": "如果姑获鸟死亡，获得主谋能力的姑获鸟保留主谋的能力。"}, {"ownerId": "guhuoniao", "targetId": "evil_twin", "ownerEn": "Guhuo", "targetEn": "Evil Twin", "newCn": "如果姑获鸟获得了镜像双子的能力，新对立双子会知道“姑获鸟在场”，但不会知道姑获鸟是谁。"}, {"ownerId": "guhuoniao", "targetId": "goblin", "ownerEn": "Guhuo", "targetEn": "Goblin", "newCn": "姑获鸟无法获得哥布林的能力。"}, {"ownerId": "guhuoniao", "targetId": "psychopath", "ownerEn": "Guhuo", "targetEn": "Psychopath", "newCn": "如果姑获鸟获得了精神病患者的能力，他会在被处决时死亡。"}, {"ownerId": "heretic", "targetId": "humeiniang", "ownerEn": "Heretic", "targetEn": "Hu Meiniang", "newCn": "互为克星的角色在同一时间里只能有其中一个角色在场。"}, {"ownerId": "kazali", "targetId": "banxian", "ownerEn": "Kazali", "targetEn": "Banxian", "newCn": "卡扎力可以把半仙转变成邪恶的爪牙。"}, {"ownerId": "kazali", "targetId": "heshang", "ownerEn": "Kazali", "targetEn": "Heshang", "newCn": "卡扎力可以把与和尚邻近的玩家转变成邪恶的爪牙。"}, {"ownerId": "legion", "targetId": "politician", "ownerEn": "Legion", "targetEn": "Politician", "newCn": "政客可能会被军团当作邪恶玩家。"}, {"ownerId": "legion", "targetId": "magician", "ownerEn": "Legion", "targetEn": "Magician", "newCn": "魔术师会和军团一同被唤醒，并可能被当作邪恶阵营。军团会知道魔术师是否在场，但不会得知具体是哪一名玩家。"}, {"ownerId": "leviathan", "targetId": "heshang", "ownerEn": "Leviathan", "targetEn": "Heshang", "newCn": "如果利维坦提名并处决了与和尚邻近的其中一名存活玩家，善良阵营获胜。"}, {"ownerId": "leviathan", "targetId": "limao", "ownerEn": "Leviathan", "targetEn": "Li Mao", "newCn": "每个夜晚*，利维坦要选择一名存活的善良玩家（与之前的每个夜晚不同）：如果“太子”被选择，他会与狸猫交换角色但不会死亡。"}, {"ownerId": "leviathan", "targetId": "xuncha", "ownerEn": "Leviathan", "targetEn": "Patrolman", "newCn": "如果利维坦在场，巡察保护的玩家免疫所有邪恶阵营的负面效果。"}, {"ownerId": "leviathan", "targetId": "dayangren", "ownerEn": "Leviathan", "targetEn": "Firewatcher", "newCn": "如果利维坦提名并处决了打更人上个夜晚猜测的其中一名玩家，善良阵营获胜。"}, {"ownerId": "lil_monsta", "targetId": "psychopath", "ownerEn": "Lil' Monsta", "targetEn": "Psychopath", "newCn": "如果精神病患者正照看小怪宝，他会在被处决时死亡。"}, {"ownerId": "lleech", "targetId": "banxian", "ownerEn": "Lleech", "targetEn": "Banxian", "newCn": "痢蛭的宿主及其中毒效果无法被转移。"}, {"ownerId": "lleech", "targetId": "shijie", "ownerEn": "Lleech", "targetEn": "Envoy", "newCn": "痢蛭的宿主及其中毒效果无法被转移。"}, {"ownerId": "lleech", "targetId": "qianke", "ownerEn": "Lleech", "targetEn": "Broker", "newCn": "痢蛭的宿主及其中毒效果无法被转移。"}, {"ownerId": "marionette", "targetId": "magician", "ownerEn": "Marionette", "targetEn": "Magician", "newCn": "如果魔术师存活，恶魔不会得知谁是提线木偶。"}, {"ownerId": "marionette", "targetId": "mathematician", "ownerEn": "Marionette", "targetEn": "Mathematician", "newCn": "数学家可能会得知提线木偶产生了错误信息或“能力未正常生效”。"}, {"ownerId": "marionette", "targetId": "guhuoniao", "ownerEn": "Marionette", "targetEn": "Guhuo", "newCn": "姑获鸟无法获得提线木偶的能力。"}, {"ownerId": "mastermind", "targetId": "zombuul", "ownerEn": "Mastermind", "targetEn": "Zombuul", "newCn": "如果亡骨魔死亡，被亡骨魔杀死的主谋依然保留能力。"}, {"ownerId": "mathematician", "targetId": "drunk", "ownerEn": "Mathematician", "targetEn": "Drunk", "newCn": "数学家可能会得知酒鬼产生了错误信息或“能力未正常生效”。"}, {"ownerId": "plague_doctor", "targetId": "humeiniang", "ownerEn": "Plague Doctor", "targetEn": "Hu Meiniang", "newCn": "如果说书人本应获得狐媚娘的能力，改为一名爪牙玩家获得此能力，且他会得知此事。"}, {"ownerId": "plague_doctor", "targetId": "witch", "ownerEn": "Plague Doctor", "targetEn": "Witch", "newCn": "如果说书人本应获得养蛊人的能力，改为一名爪牙玩家获得此能力，且他会得知此事。"}, {"ownerId": "recluse", "targetId": "sage", "ownerEn": "Recluse", "targetEn": "Sage", "newCn": "陌客可能会被贤者当作杀死他的恶魔。"}, {"ownerId": "riot", "targetId": "xuncha", "ownerEn": "Riot", "targetEn": "Patrolman", "newCn": "如果暴乱在场，巡察保护的玩家免疫所有邪恶阵营的负面效果。"}, {"ownerId": "riot", "targetId": "atheist", "ownerEn": "Riot", "targetEn": "Atheist", "newCn": "在暴乱的提名链中，如果说书人被提名，玩家要进行投票。如果说书人“即将被处决”，游戏结束；否则，说书人要重新发起提名。"}, {"ownerId": "riot", "targetId": "banxian", "ownerEn": "Riot", "targetEn": "Banxian", "newCn": "当且仅当暴乱提名了半仙时，半仙不会死亡，而是让另一名存活的邪恶玩家死亡。（随后那名死亡的邪恶玩家可以立即发起新的提名。如果场上已经没有其他存活的邪恶玩家，那么半仙在被唯一存活的暴乱提名时会正常死亡。）"}, {"ownerId": "riot", "targetId": "dayangren", "ownerEn": "Riot", "targetEn": "Firewatcher", "newCn": "如果暴乱提名并处决了打更人上个夜晚猜测的其中一名玩家，善良阵营获胜。"}, {"ownerId": "riot", "targetId": "heshang", "ownerEn": "Riot", "targetEn": "Heshang", "newCn": "如果暴乱提名并处决了与和尚邻近的其中一名存活玩家，善良阵营获胜。"}, {"ownerId": "riot", "targetId": "limao", "ownerEn": "Riot", "targetEn": "Li Mao", "newCn": "每个夜晚*，暴乱要选择一名存活的善良玩家（与之前的每个夜晚不同）：如果“太子”被选择，他会与狸猫交换角色但不会死亡。"}, {"ownerId": "summoner", "targetId": "guhuoniao", "ownerEn": "Summoner", "targetEn": "Guhuo", "newCn": "如果召唤师成功召唤了姑获鸟，召唤师会变成一个不在场的爪牙，姑获鸟本局游戏中无法获得爪牙能力。"}, {"ownerId": "vizier", "targetId": "guhuoniao", "ownerEn": "Vizier", "targetEn": "Guhuo", "newCn": "姑获鸟无法获得维齐尔的能力。"}, {"ownerId": "wudaozhe", "targetId": "mathematician", "ownerEn": "Enlightened One", "targetEn": "Mathematician", "newCn": "数学家可能会得知悟道者产生了错误信息或“能力未正常生效”。"}, {"ownerId": "xizi", "targetId": "atheist", "ownerEn": "Actor", "targetEn": "Atheist", "newCn": "无神论者在剧本中时，处决说书人导致的胜负结果不会被反转。"}, {"ownerId": "xizi", "targetId": "boffin", "ownerEn": "Actor", "targetEn": "Boffin", "newCn": "科学怪人无法使恶魔获得戏子（改）的能力。"}, {"ownerId": "xizi", "targetId": "damsel", "ownerEn": "Actor", "targetEn": "Damsel", "newCn": "落难少女不会因为戏子（改）的能力醉酒。"}, {"ownerId": "xizi", "targetId": "evil_twin", "ownerEn": "Actor", "targetEn":